{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@utk09/finra-ui": ["./packages/core/src/index.ts"],
      "@utk09/finra-ui/*": ["./packages/core/src/*"],
      "@utk09/finra-ui-finance": ["./packages/finance/src/index.ts"],
      "@utk09/finra-ui-finance/*": ["./packages/finance/src/*"],
      "@utk09/finra-ui-icons": ["./packages/icons/src/index.ts"],
      "@utk09/finra-ui-icons/*": ["./packages/icons/src/*"]
    },
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  }
}
